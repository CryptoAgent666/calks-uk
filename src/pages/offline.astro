---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Offline — Calks.uk" description="You are currently offline." noindex={true}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16 text-center">
    <p class="text-5xl mb-4">📡</p>
    <h1 class="text-2xl font-bold tracking-tight mb-2">You're offline</h1>
    <p class="text-muted-foreground mb-8">Check your internet connection and try again. Previously visited calculators may still be available.</p>
    <button onclick="window.location.reload()" class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
      Try again
    </button>
  </div>
</Layout>
