---
import Layout from '@/layouts/Layout.astro'
import { CATEGORIES } from '@/data/categories'
import type { CategoryId } from '@/data/types'

const popularCategories: CategoryId[] = ['tax', 'pay', 'mortgage', 'pension', 'business', 'tools']
---

<Layout title="Page Not Found — Calks.uk" description="The page you were looking for could not be found. Browse our 330+ free UK calculators.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16 text-center">
    <p class="text-7xl font-bold text-primary/20 mb-4">404</p>
    <h1 class="text-2xl font-bold tracking-tight mb-2">Page not found</h1>
    <p class="text-muted-foreground mb-8">The page you were looking for doesn't exist or has been moved.</p>

    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <a href="/" class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Homepage
      </a>
      <a href="/search/" class="inline-flex items-center gap-2 rounded-lg border border-border px-5 py-2.5 text-sm font-medium hover:bg-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        Search calculators
      </a>
    </div>

    <h2 class="text-lg font-semibold mb-4">Popular categories</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {popularCategories.map((catId) => (
        <a
          href={`/category/${catId}/`}
          class="flex items-center gap-2.5 rounded-xl border border-border p-3 hover:bg-accent transition-colors"
        >
          <div class={`flex h-8 w-8 items-center justify-center rounded-lg ${CATEGORIES[catId].color}`} aria-hidden="true">
            <span class={`text-xs font-bold ${CATEGORIES[catId].iconColor}`}>{CATEGORIES[catId].name.charAt(0)}</span>
          </div>
          <span class="text-sm font-medium">{CATEGORIES[catId].name}</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
