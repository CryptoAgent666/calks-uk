---
import Layout from '@/layouts/Layout.astro'
import { getWebPageSchema, getBreadcrumbSchema } from '@/utils/seo'

const schemas = [
  getWebPageSchema('Updates', 'Rate changes, new calculators and improvements to Calks.uk. Stay up to date with our latest updates.', '/updates/', '2026-06-10'),
  getBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Updates', url: '/updates/' },
  ]),
]
---

<Layout title="Updates" description="Rate changes, new calculators and improvements to Calks.uk. Stay up to date with our latest updates." schemas={schemas}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <span>/</span>
      <span class="text-foreground font-medium">Updates</span>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight mb-2">Updates</h1>
    <p class="text-sm text-muted-foreground mb-8">Rate changes, new calculators and site improvements</p>

    <div class="space-y-8">
      <!-- June 2026 — App Store launch -->
      <article class="relative pl-8 border-l-2 border-primary/20">
        <div class="absolute -left-2 top-0 h-4 w-4 rounded-full bg-primary"></div>
        <div class="mb-2">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            June 2026
          </span>
        </div>
        <h2 class="text-lg font-semibold mb-2">Now on the App Store — native iOS app launched</h2>
        <ul class="text-sm text-muted-foreground space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Calks.UK is on the App Store</strong> — download the free app for iPhone and iPad: <a href="https://apps.apple.com/gb/app/calks-uk-uk-calculators/id6776149190" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">Calks.UK on the App Store</a></span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Works fully offline</strong> — all 330+ calculators in your pocket, no connection needed</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Always current</strong> — rate changes and new calculators arrive automatically, no app update required</span>
          </li>
        </ul>
      </article>

      <!-- April 2026 -->
      <article class="relative pl-8 border-l-2 border-primary/20">
        <div class="absolute -left-2 top-0 h-4 w-4 rounded-full bg-primary"></div>
        <div class="mb-2">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            April 2026
          </span>
        </div>
        <h2 class="text-lg font-semibold mb-2">2026/27 Tax Year — Full Rate Update</h2>
        <ul class="text-sm text-muted-foreground space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">All tax calculators updated</strong> — Income Tax, National Insurance, Capital Gains Tax, Dividend Tax, Stamp Duty and more now reflect 2026/27 rates effective from 6 April 2026</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">National Living Wage</strong> — Increased to &pound;12.71/hr for 21+ (was &pound;12.21), &pound;10.85 for 18–20 (was &pound;10.00), &pound;8.00 for under 18 / apprentice (was &pound;7.55)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">State Pension</strong> — Triple-lock uprating to &pound;241.30/week (&pound;12,547.60/year), up from &pound;221.20/week</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Student loan thresholds</strong> — Plan 1: &pound;26,900 (was &pound;24,990), Plan 2: &pound;29,385 (was &pound;27,295), Plan 4: &pound;33,795 (was &pound;31,395). Plan 5 frozen at &pound;25,000</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Statutory pay rates</strong> — SSP up to &pound;123.25/week (was &pound;116.75), SMP/SPP &pound;194.32/week (was &pound;187.18)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Child Benefit</strong> — Eldest child &pound;27.05/week (was &pound;26.05), additional children &pound;17.90/week (was &pound;17.25 each)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Frozen rates</strong> — Personal Allowance (&pound;12,570), tax bands, NI rates (8%/2%/15%), VAT (20%), Stamp Duty bands, ISA (&pound;20,000), CGT exemption (&pound;3,000) and Inheritance Tax (&pound;325k/&pound;175k) all unchanged from 2025/26</span>
          </li>
        </ul>
      </article>

      <!-- Launch -->
      <article class="relative pl-8 border-l-2 border-primary/20">
        <div class="absolute -left-2 top-0 h-4 w-4 rounded-full bg-primary"></div>
        <div class="mb-2">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            April 2026
          </span>
        </div>
        <h2 class="text-lg font-semibold mb-2">Calks.uk Launch</h2>
        <ul class="text-sm text-muted-foreground space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">330+ calculators</strong> — Launched with over 330 free UK calculators covering tax, salary, mortgage, pensions, VAT, benefits, business and more</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">20 categories</strong> — Tax & HMRC, Salary & Employment, Mortgage & Property, Pensions, Savings, Loans, Business, Benefits, Motoring, Health, Construction, Energy, Education, Everyday, Insurance, Immigration, Legal, Farming, Maths and Gardening</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">Privacy first</strong> — All calculations run in your browser. No personal data is collected or stored</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">Dark mode</strong> — Full dark mode support across the entire site</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">Mobile optimised</strong> — Responsive design that works on phones, tablets and desktops</span>
          </li>
        </ul>
      </article>

      <!-- Coming Soon -->
      <div class="mt-12 rounded-xl border border-border bg-muted/30 p-6">
        <h2 class="text-base font-semibold mb-2">Coming Soon</h2>
        <ul class="text-sm text-muted-foreground space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500 shrink-0"></span>
            <span>Save and share calculator results</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500 shrink-0"></span>
            <span>PDF export for tax calculations</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500 shrink-0"></span>
            <span>Historical tax year comparisons</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500 shrink-0"></span>
            <span>Save and share calculator results</span>
          </li>
        </ul>
      </div>

      <p class="text-sm text-muted-foreground">
        Want to be notified of major updates? Email <a href="mailto:info@calks.uk" class="text-primary hover:underline">info@calks.uk</a> with "Updates" in the subject line.
      </p>
    </div>
  </div>
</Layout>
