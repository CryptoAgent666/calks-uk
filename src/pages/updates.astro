---
import Layout from '@/layouts/Layout.astro'
import { getWebPageSchema } from '@/utils/seo'

const schemas = [getWebPageSchema('Updates', 'Rate changes, new calculators and improvements to Calks.uk. Stay up to date with our latest updates.', '/updates/', '2026-04-06')]
---

<Layout title="Updates" description="Rate changes, new calculators and improvements to Calks.uk. Stay up to date with our latest updates." schemas={schemas}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-muted-foreground mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <span>/</span>
      <span class="text-foreground font-medium">Updates</span>
    </nav>

    <h1 class="text-3xl font-bold tracking-tight mb-2">Updates</h1>
    <p class="text-sm text-muted-foreground mb-8">Rate changes, new calculators and site improvements</p>

    <div class="space-y-8">
      <!-- April 2026 -->
      <article class="relative pl-8 border-l-2 border-primary/20">
        <div class="absolute -left-2 top-0 h-4 w-4 rounded-full bg-primary"></div>
        <div class="mb-2">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            April 2026
          </span>
        </div>
        <h2 class="text-lg font-semibold mb-2">2025/26 Tax Year — Full Rate Update</h2>
        <ul class="text-sm text-muted-foreground space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">All tax calculators updated</strong> — Income Tax, National Insurance, Capital Gains Tax, Dividend Tax, Stamp Duty and more now reflect 2025/26 rates effective from 6 April 2025</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Employer NI increase</strong> — Updated Employer National Insurance Calculator to 15% rate (up from 13.8%) with new &pound;5,000 threshold</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Stamp Duty changes</strong> — First-time buyer threshold reverted to &pound;300,000, standard nil-rate band to &pound;125,000</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Student loan thresholds</strong> — Updated all plan thresholds (Plan 1: &pound;24,990, Plan 2: &pound;27,295, Plan 4: &pound;31,395, Plan 5: &pound;25,000)</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Pension annual allowance</strong> — Updated to &pound;60,000 with Money Purchase Annual Allowance at &pound;10,000</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-green-500 shrink-0"></span>
            <span><strong class="text-foreground">Benefits rates</strong> — Universal Credit, Child Benefit, State Pension and statutory pay rates updated for 2025/26</span>
          </li>
        </ul>
      </article>

      <!-- Launch -->
      <article class="relative pl-8 border-l-2 border-primary/20">
        <div class="absolute -left-2 top-0 h-4 w-4 rounded-full bg-primary"></div>
        <div class="mb-2">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-medium text-primary">
            April 2026
          </span>
        </div>
        <h2 class="text-lg font-semibold mb-2">Calks.uk Launch</h2>
        <ul class="text-sm text-muted-foreground space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">330+ calculators</strong> — Launched with over 330 free UK calculators covering tax, salary, mortgage, pensions, VAT, benefits, business and more</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">20 categories</strong> — Tax & HMRC, Salary & Employment, Mortgage & Property, Pensions, Savings, Loans, Business, Benefits, Motoring, Health, Construction, Energy, Education, Everyday, Insurance, Immigration, Legal, Farming, Maths and Gardening</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">Privacy first</strong> — All calculations run in your browser. No personal data is collected or stored</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">Dark mode</strong> — Full dark mode support across the entire site</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-500 shrink-0"></span>
            <span><strong class="text-foreground">Mobile optimised</strong> — Responsive design that works on phones, tablets and desktops</span>
          </li>
        </ul>
      </article>

      <!-- Coming Soon -->
      <div class="mt-12 rounded-xl border border-border bg-muted/30 p-6">
        <h2 class="text-base font-semibold mb-2">Coming Soon</h2>
        <ul class="text-sm text-muted-foreground space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500 shrink-0"></span>
            <span>Save and share calculator results</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500 shrink-0"></span>
            <span>PDF export for tax calculations</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500 shrink-0"></span>
            <span>Historical tax year comparisons</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-amber-500 shrink-0"></span>
            <span>Save and share calculator results</span>
          </li>
        </ul>
      </div>

      <p class="text-sm text-muted-foreground">
        Want to be notified of major updates? Email <a href="mailto:info@calks.uk" class="text-primary hover:underline">info@calks.uk</a> with "Updates" in the subject line.
      </p>
    </div>
  </div>
</Layout>
