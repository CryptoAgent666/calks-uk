---
import { CATEGORIES } from '@/data/categories'
import type { CategoryId } from '@/data/types'

const currentYear = new Date().getFullYear()
const FOOTER_CATEGORIES: CategoryId[] = ['tax', 'pay', 'pension', 'mortgage', 'loans', 'business', 'investment', 'benefits', 'auto', 'health', 'building', 'energy', 'education', 'tools']
---

<footer class="border-t border-border bg-muted/30">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 py-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- About -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2.5 min-h-[44px]">
          <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-gradient-to-br from-blue-700 to-blue-900 shadow-lg shadow-blue-600/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><line x1="8" x2="16" y1="6" y2="6"/><line x1="16" x2="16" y1="14" y2="18"/><path d="M16 10h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M12 14h.01"/><path d="M8 14h.01"/><path d="M12 18h.01"/><path d="M8 18h.01"/></svg>
          </div>
          <span class="text-lg font-bold"><span class="text-gradient-uk">Calks</span><span class="text-muted-foreground">.uk</span></span>
        </a>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Free online calculators for the United Kingdom. Tax, salary, mortgage, pension, VAT and more — updated for the 2026/27 tax year.
        </p>
        <a
          href="mailto:info@calks.uk"
          class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors py-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          info@calks.uk
        </a>
        {/* Store badges — App Store (iOS) + Google Play (Android), shown on web and on
            the other native app. The whole block is hidden inside the iOS app via the
            `is-ios-app` class (Layout.astro); the Google Play badge is additionally
            omitted from the iOS binary entirely (PUBLIC_IS_IOS_BUILD). Guideline 2.3.10. */}
        <div class="store-badges flex flex-wrap items-center gap-3">
        <a
          href="https://apps.apple.com/gb/app/calks-uk-uk-calculators/id6776149190"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Download Calks.UK on the App Store"
          class="appstore-badge inline-block transition-opacity hover:opacity-80"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="160" height="48" viewBox="0 0 180 54" aria-hidden="true">
            <rect width="180" height="54" rx="8" fill="#000000"/>
            <rect x="0.5" y="0.5" width="179" height="53" rx="7.5" fill="none" stroke="#a6a6a6" stroke-width="1"/>
            <!-- Apple logo -->
            <path transform="translate(12, 10) scale(1.45)" fill="#ffffff" d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.51 4.09l-.01-.01zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            <!-- Text -->
            <text x="54" y="23" font-family="-apple-system, 'Helvetica Neue', Arial, sans-serif" font-size="9" fill="#ffffff">Download on the</text>
            <text x="53" y="42" font-family="-apple-system, 'Helvetica Neue', Arial, sans-serif" font-size="18" font-weight="600" fill="#ffffff">App Store</text>
          </svg>
        </a>
        {import.meta.env.PUBLIC_IS_IOS_BUILD !== '1' && (
        <a
          href="https://play.google.com/store/apps/details?id=uk.calks.app"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get it on Google Play"
          class="gplay-badge inline-block transition-opacity hover:opacity-80"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="160" height="48" viewBox="0 0 180 54" aria-hidden="true">
            <rect width="180" height="54" rx="8" fill="#000000"/>
            <rect x="0.5" y="0.5" width="179" height="53" rx="7.5" fill="none" stroke="#a6a6a6" stroke-width="1"/>
            <!-- Google Play triangle icon -->
            <g transform="translate(12, 11)">
              <path d="M.5.5v31L16 16 .5.5z" fill="#4285F4"/>
              <path d="M.5.5L16 16 .5 31.5c-.3-.2-.5-.5-.5-.9V1.4c0-.4.2-.7.5-.9z" fill="#4285F4"/>
              <path d="M21 11L16 16l5 5 7.7-4.3c.9-.5.9-1.9 0-2.4L21 11z" fill="#FBBC04"/>
              <path d="M16 16L.5 31.5c.3.2.7.3 1.1.1L21 21l-5-5z" fill="#EA4335"/>
              <path d="M.5.5c-.4-.2-.8-.1-1.1.1.4.2.8.3 1.1.1L16 16 21 11 1.6.4C1.2.2.8.3.5.5z" fill="#34A853" transform="translate(0, 0)"/>
            </g>
            <!-- Text -->
            <text x="48" y="22" font-family="Roboto, Arial, sans-serif" font-size="9" fill="#ffffff">GET IT ON</text>
            <text x="48" y="40" font-family="Roboto, Arial, sans-serif" font-size="17" font-weight="600" fill="#ffffff">Google Play</text>
          </svg>
        </a>
        )}
        </div>
      </div>

      <!-- Categories -->
      <div class="space-y-4">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
          Calculators
        </h3>
        <ul class="space-y-2.5">
          {FOOTER_CATEGORIES.map((catId) => (
            <li>
              <a
                href={`/category/${catId}/`}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block"
              >
                {CATEGORIES[catId].name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Popular -->
      <div class="space-y-4">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
          Popular
        </h3>
        <ul class="space-y-2.5">
          <li><a href="/calculator/income-tax-calculator/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Income Tax Calculator</a></li>
          <li><a href="/calculator/take-home-pay-calculator/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Take-Home Pay Calculator</a></li>
          <li><a href="/calculator/vat-calculator/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">VAT Calculator</a></li>
          <li><a href="/calculator/stamp-duty-calculator/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Stamp Duty Calculator</a></li>
          <li><a href="/calculator/mortgage-repayment-calculator/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Mortgage Calculator</a></li>
          <li><a href="/calculator/national-insurance-calculator/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">National Insurance Calculator</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="space-y-4">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-foreground">
          Information
        </h3>
        <ul class="space-y-2.5">
          <li><a href="/calculators/" class="text-sm font-medium text-foreground hover:text-primary transition-colors py-1.5 inline-block">All Calculators (A–Z)</a></li>
          <li><a href="/about/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">About</a></li>
          <li><a href="/privacy/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Privacy Policy</a></li>
          <li><a href="/terms/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Terms of Use</a></li>
          <li><a href="/methodology/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Methodology</a></li>
          <li><a href="/contact/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Contact</a></li>
          <li><a href="/updates/" class="text-sm text-muted-foreground hover:text-foreground transition-colors py-1.5 inline-block">Updates</a></li>
        </ul>
        <p class="text-xs text-muted-foreground/70 leading-relaxed pt-2">
          All calculations are performed in your browser. No personal data is collected or sent to our servers. Results are for guidance only — always verify with HMRC or a qualified professional.
        </p>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-border py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-muted-foreground">
        &copy; {currentYear} Calks.uk. All rights reserved.
      </p>
      <div class="flex items-center gap-2 text-xs text-muted-foreground/60">
        <p>Data sourced from HMRC &amp; GOV.UK</p>
        <span class="hidden sm:inline">|</span>
        <p>Made for the United Kingdom</p>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  /* App Store guideline 2.3.10: shared OTA bundles still ship the store badges,
     so the iOS app sets `is-ios-app` on <html> before paint to hide them.
     The native binary also omits the Google Play badge via PUBLIC_IS_IOS_BUILD. */
  html.is-ios-app .store-badges { display: none !important; }
</style>
