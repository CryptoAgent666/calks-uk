---
/**
 * "Quick Answer" / TL;DR block — optimised for AI citation
 * (ChatGPT Search, Perplexity, Google AI Overviews, Bing Copilot).
 * Clear, factual 1-3 sentence summary above the fold.
 */
interface Props {
  answer: string
}
const { answer } = Astro.props
---

<div class="mb-6 rounded-xl border-l-4 border-primary bg-primary/5 p-4 sm:p-5">
  <p class="text-xs font-semibold uppercase tracking-wider text-primary mb-1.5 flex items-center gap-1.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    Quick Answer
  </p>
  <p class="text-sm sm:text-base leading-relaxed text-foreground" set:html={answer} />
</div>
