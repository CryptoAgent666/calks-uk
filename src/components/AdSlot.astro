---
interface Props {
  type?: 'responsive' | 'rectangle' | 'leaderboard'
  class?: string
}

const { type = 'responsive', class: className = '' } = Astro.props
const slotClass = `ad-slot-${type}`
---

<div class={`${slotClass} ${className}`} data-no-print style={type === 'rectangle' ? 'min-height:250px' : type === 'leaderboard' ? 'min-height:90px' : 'min-height:90px'}>
  <!-- AdSense ad unit will be inserted here -->
  <!-- <ins class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-XXXXXXX"
    data-ad-slot="XXXXXXX"
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script> -->
</div>
