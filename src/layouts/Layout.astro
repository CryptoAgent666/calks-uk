---
import '@/styles/global.css'
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import CookieConsent from '@/components/CookieConsent.astro'
import { getPersonSchema } from '@/utils/seo'

// Person schema is inlined on every page so #author @id references resolve sitewide
const personSchema = getPersonSchema()

interface Props {
  title: string
  description?: string
  canonicalUrl?: string
  schemas?: object[]
  ogImage?: string
  noindex?: boolean
}

const {
  title,
  description = 'Free online calculators for the UK. Tax, salary, mortgage, pension, VAT, stamp duty and more — updated for 2026/27 tax year.',
  canonicalUrl,
  schemas = [],
  ogImage = '/og-default.png',
  noindex = false,
} = Astro.props

const siteUrl = 'https://calks.uk'
const fullTitle = title.includes('Calks.uk') ? title : `${title} | Calks.uk`
const canonical = canonicalUrl || `${siteUrl}${Astro.url.pathname}`
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Preconnect / DNS prefetch — speeds up early third-party fetches -->
    <link rel="preconnect" href="https://calks.uk" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Calks.uk" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en-GB" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Fonts (self-hosted) — fetchpriority high for LCP text -->
    <link rel="preload" href="/fonts/inter-variable-subset.woff2" as="font" type="font/woff2" crossorigin fetchpriority="high" />

    <!-- Theme color -->
    <meta name="theme-color" content="#1e3a5f" />

    <!-- Google AdSense — site ownership verification (static, independent of cookie consent) -->
    <meta name="google-adsense-account" content="ca-pub-4859241862365215" />

    <!-- Schema.org JSON-LD: per-page schemas + site-wide Person -->
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Theme (prevent FOUC) -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme')
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
      })()
      document.documentElement.classList.toggle('dark', theme === 'dark')
    </script>

    <!-- Detect Capacitor WebView (mobile app) — reliable via hostname -->
    <script is:inline>
      window.__IS_CAPACITOR__ =
        window.location.hostname === 'localhost' ||
        window.location.protocol === 'capacitor:' ||
        window.location.protocol === 'file:' ||
        !!window.Capacitor;

      // On the iOS native app, hide the store badge in the footer (App Store guideline 2.3.10).
      // Set a class on <html> before paint so the badge never flashes.
      // Android and web keep the badge. Works for OTA bundles too (single shared bundle).
      try {
        if (window.Capacitor && typeof window.Capacitor.getPlatform === 'function'
            && window.Capacitor.getPlatform() === 'ios') {
          document.documentElement.classList.add('is-ios-app');
        }
      } catch (_) {}

      // In Capacitor WebView, trailing-slash URLs don't auto-resolve to index.html.
      // Rewrite <a href="/path/"> clicks to navigate to /path/index.html instead.
      if (window.__IS_CAPACITOR__) {
        document.addEventListener('click', function(e) {
          var a = e.target.closest ? e.target.closest('a') : null;
          if (!a || !a.href) return;
          var url;
          try { url = new URL(a.href); } catch(_) { return; }
          // Only rewrite same-origin internal links ending with '/'
          if (url.origin !== window.location.origin) return;
          if (!url.pathname.endsWith('/')) return;
          if (a.target && a.target !== '_self') return;
          e.preventDefault();
          window.location.href = url.origin + url.pathname + 'index.html' + url.search + url.hash;
        }, true);

        // Also rewrite history.pushState / replaceState if any client-side routing uses them
        // (none in this app, but defensive)
      }
    </script>

    <!-- Google Analytics (consent-gated, skipped in mobile app) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      if (!window.__IS_CAPACITOR__ && localStorage.getItem('cookie-consent') === 'accepted') {
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-7ZTS02YTBC';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-7ZTS02YTBC');
      }
    </script>

    <!-- Google AdSense Auto Ads — static tag so AdSense can verify ownership and the reviewer/crawler can see it. -->
    <!-- GDPR/UK consent for ad personalisation is handled by Google's consent message (CMP), configured in the AdSense dashboard. -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4859241862365215" crossorigin="anonymous"></script>
    <!-- AdSense web ads aren't permitted inside the native (Capacitor) app webview — remove the tag there before it runs. -->
    <script is:inline>
      if (window.__IS_CAPACITOR__) {
        var __adsTag = document.querySelector('script[src*="adsbygoogle.js"]');
        if (__adsTag) __adsTag.remove();
      }
    </script>

    <!-- OTA live-updates: native app pulls new web bundles from Cloudflare (no-op on the website) -->
    <script>
      import { initOtaUpdates } from '../scripts/ota-update'
      initOtaUpdates()
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased bg-background text-foreground">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        if (window.__IS_CAPACITOR__) {
          // Unregister any existing SW + clear caches (left from previous versions)
          navigator.serviceWorker.getRegistrations().then(function(regs){
            regs.forEach(function(r){ r.unregister(); });
          }).catch(function(){});
          if (window.caches) {
            caches.keys().then(function(keys){
              keys.forEach(function(k){ caches.delete(k); });
            }).catch(function(){});
          }
        } else {
          navigator.serviceWorker.register('/sw.js').catch(function(){});
        }
      }
    </script>
  </body>
</html>
