{
  "name": "astro-tmp",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "build:android": "PUBLIC_BUILD_ID=$(date +%Y%m%d%H%M) astro build && npx cap sync android",
    "build:ios": "PUBLIC_IS_IOS_BUILD=1 PUBLIC_BUILD_ID=$(date +%Y%m%d%H%M) astro build && npx cap sync ios",
    "deploy": "node scripts/deploy.mjs"
  },
  "dependencies": {
